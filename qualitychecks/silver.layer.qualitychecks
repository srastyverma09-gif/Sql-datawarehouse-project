-----------------------------------------------------------------------------------------------------------


--FOR NULLS 
 SELECT SLS_ORD_NUM, SLS_CUST_ID
 FROM SILVER.CRM_SALES_DETAILS
 WHERE  SLS_ORD_NUM  IS NULL AND  sls_cust_id IS NULL 
 ------------------------------------------------------------------------------------------------------------

 -- FOR UNAVAILABLE PRODUCT KEY(PRD_KEY PRESENT IN SILVER.CRM_SALES_DETAILS BUT NOT IN SILVER.CRM_PRD_INFO)
SELECT SLS_PRD_KEY
FROM SILVER.CRM_SALES_DETAILS
WHERE SLS_PRD_KEY NOT IN (SELECT PRD_KEY FROM SILVER.CRM_PRD_INFO )
 ------------------------------------------------------------------------------------------------------------

 -- FOR UNAVAILABLE CUSTOMER ID (CUST_ID PRESENT IN SILVER.CRM_SALES_DETAILS BUT NOT IN SILVER.CRM_CUST_INFO)
SELECT SLS_CUST_ID 
FROM SILVER.CRM_SALES_DETAILS
WHERE SLS_CUST_ID  NOT IN (SELECT CST_ID FROM SILVER.CRM_CUST_INFO)
 ------------------------------------------------------------------------------------------------------------
 --ORDER DATE
 SELECT SLS_ORDER_DT
 FROM SILVER.CRM_SALES_DETAILS
 WHERE LEN(SLS_ORDER_DT)<>8
 ------------------------------------------------------------------------------------------------------------ 
 --CONVERT INTEGER ORDER DATE TO STRING THEN TO DATE
 SELECT   CAST(CAST(SLS_ORDER_DT AS VARCHAR) AS DATE) SLS_ORDER_DT
  FROM SILVER.CRM_SALES_DETAILS
  WHERE LEN(SLS_ORDER_DT)=8
 ------------------------------------------------------------------------------------------------------------ 
--SHIPDATE
 SELECT SLS_ORDER_DT
 FROM SILVER.CRM_SALES_DETAILS
 WHERE LEN(SLS_ORDER_DT)<>8 OR SLS_ORDER_DT IS NULL
 ------------------------------------------------------------------------------------------------------------ 
 --CONVERT INTEGER ORDER DATE TO STRING THEN TO DATE
 SELECT   CAST(CAST(SLS_SHIP_DT AS VARCHAR) AS DATE) SLS_SHIP_DT
  FROM SILVER.CRM_SALES_DETAILS
  WHERE LEN(SLS_SHIP_DT)=8
 ------------------------------------------------------------------------------------------------------------ 
   --DUE DATE
 SELECT SLS_DUE_DT
 FROM SILVER.CRM_SALES_DETAILS
 WHERE LEN(SLS_DUE_DT)=8 

 ------------------------------------------------------------------------------------------------------------ 
 --CONVERT INTEGER DUE DATE TO STRING THEN TO DATE
 SELECT   CAST(CAST(SLS_DUE_DT AS VARCHAR) AS DATE) SLS_DUE_DT
  FROM SILVER.CRM_SALES_DETAILS
  WHERE LEN(SLS_DUE_DT)=8 OR
            SLS_DUE_DT<SLS_ORDER_DT
------------------------------------------------------------------------------------------------------------ 
--NULLS , ZEROS OR NEGATIVE VALUES IN SLS_SALES
SELECT SLS_SALES 
FROM   SILVER.CRM_SALES_DETAILS
WHERE  SLS_SALES<> ABS(SLS_SALES ) OR SLS_SALES  IS NULL OR SLS_SALES =0
------------------------------------------------------------------------------------------------------------ 
--NULLS , ZEROS OR NEGATIVE VALUES IN SLS_QUANTITY
SELECT SLS_QUANTITY 
FROM   SILVER.CRM_SALES_DETAILS
WHERE SLS_QUANTITY<> ABS(SLS_QUANTITY ) OR SLS_QUANTITY  IS NULL OR SLS_QUANTITY =0
------------------------------------------------------------------------------------------------------------
--NULLS , ZEROS OR NEGATIVE VALUES IN SLS_PRICE
SELECT SLS_PRICE 
FROM   SILVER.CRM_SALES_DETAILS
WHERE  SLS_PRICE<> ABS(SLS_PRICE ) OR SLS_PRICE  IS NULL OR SLS_PRICE=0

