/*  This script contains quality checks for all the 6 tables. 
Data Quality Checks (Silver Layer)

The purpose of this script is to validate and improve data quality by identifying:

Duplicate records
Null and missing values
Invalid dates and numeric values
Data standardization issues
Referential integrity issues
Formatting inconsistences

These checks should be executed after the Silver layer has been successfully loaded to ensure the 
data is clean, consistent, and ready for downstream processing and reporting.*/

 ------------------------------------------------------------------------------------------------------------
--QUALITY CHECK  SILVER.CRM_CUST_INFO
 ------------------------------------------------------------------------------------------------------------
--FOR DUPLICATES
SELECT CST_ID, COUNT(*) 
FROM SILVER.CRM_CUST_INFO
GROUP BY  CST_ID
HAVING COUNT(*)>1
-----------------------------------------------------------------------------------------------------------------------------
--FOR LEADING AND TRAILING SPACE
SELECT  cst_firstname,cst_lastname
FROM SILVER.CRM_CUST_INFO
WHERE cst_firstname<>TRIM(cst_firstname) AND
cst_lastname<>TRIM(cst_lastname)
-----------------------------------------------------------------------------------------------------------------------------
--DATA STANDARDRIZATION AND CONSISTENCY CHECK
SELECT cst_marital_status,
cst_gndr
FROM SILVER.CRM_CUST_INFO
WHERE cst_marital_status  NOT IN('SINGLE','MARRIED','N/A') AND
      cst_gndr NOT IN ('FEMALE','MALE','N/A')

      ------------------OR------------------
SELECT DISTINCT cst_marital_status
FROM SILVER.CRM_CUST_INFO

SELECT DISTINCT cst_gndr
FROM SILVER.CRM_CUST_INFO  
-----------------------------------------------------------------------------------------------------------------------------
--FOR DATE
SELECT CST_CREATE_DATE
FROM SILVER.CRM_CUST_INFO
WHERE TRY_CAST(CST_CREATE_DATE AS DATE ) IS NULL
        AND CST_CREATE_DATE IS NOT NULL



--------------------------------------------------------------------------------------
--QUALITY CHECK SILVER.CRM_PRD_INFO:
--------------------------------------------------------------------------------------


--DUPLICATES VALUE
SELECT COUNT(*)  PRD_ID
FROM SILVER.CRM_PRD_INFO
WHERE PRD_ID IS NOT NULL
GROUP BY PRD_ID
HAVING COUNT(*)>1 
--------------------------------------------------------------------------------------
--DIVINDIG DATA AND CHECKING NULLS IN PRD_KEY
SELECT PRD_KEY,
        REPLACE(SUBSTRING(PRD_KEY,1,5),'-','_') AS CATEGORY,
               (SUBSTRING(PRD_KEY,7,LEN(PRD_KEY))) AS PRD_KEY
FROM SILVER.CRM_PRD_INFO
WHERE PRD_KEY IS NULL
--------------------------------------------------------------------------------------
--CHECK FOR NEGATIVE AND NULL PRD_COST
SELECT COALESCE(PRD_COST,0)PRD_COST
FROM SILVER.CRM_PRD_INFO
WHERE PRD_COST IS NULL OR PRD_COST <>ABS(PRD_COST)
--------------------------------------------------------------------------------------
--DATA STANDARDIZATION 
SELECT DISTINCT
PRD_LINE 
FROM SILVER.CRM_PRD_INFO
--------------------------------------------------------------------------------------
--CHECK FOR INVALID DATES
select
prd_start_dt,
lead(prd_start_dt) over (partition by prd_key order by prd_start_dt )as prd_end_dt
from  silver .CRM_PRD_INFO



